{
  "Jwt": {
    "Issuer": "g5prj-auth-service",
    "Audience": "g5prj-clients",
    "KeyFilePath": "Resources/Security/jwt-key.txt"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5080",
      "http://localhost:3000",
      "http://localhost:5500",
      "http://127.0.0.1:5500"
    ]
  },
  "FileStorage": {
    "QuizDataFilePath": "Data/quiz-data.json"
  },
  "OracleOdbc": {
    "Enabled": true,
    "ConnectionString": "",
    "CategoriesTableName": "CATEGORIES",
    "QuestionsTableName": "QUESTIONS",
    "IndividualAnswersTableName": "INDIVIDUAL_ANSWERS",
    "ModeratedAnswersTableName": "MODERATED_ANSWERS",
    "UsersTableName": "USERS",
    "RolesTableName": "ROLES"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
