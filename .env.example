# Copy to .env before running docker compose:
#   cp .env.example .env

# Oracle ODBC connection (adjust password/service if needed)
ORACLE_ODBC_CONNECTION_STRING=Driver={Oracle23IC};Dbq=quizdb_tp;Uid=ADMIN;Pwd=<TEAM_DB_PASSWORD>;

# Wallet directory mounted into containers
ORACLE_WALLET_DIR=./docker/oracle/wallet

# Shared JWT signing key for auth-service and quiz-service
JWT_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_FOR_DEMO_USE_ONLY_123456789
